# ─────────────────────────────────────────────────────────────
# InterviewIQ — environment variables
# Copy this file to `.env.local` and fill in your own keys.
# Everything here is read ONLY on the server (the WebSocket server
# and Next.js API routes). The single exception is NEXT_PUBLIC_WS_URL,
# which the browser needs to find the realtime server.
# ─────────────────────────────────────────────────────────────

# Anthropic — the interviewer's brain, vision analysis and feedback
ANTHROPIC_API_KEY=

# ElevenLabs — realtime text-to-speech (the interviewer's voice)
ELEVENLABS_API_KEY=
# Gender-matched voices (the interviewer's name decides which is used).
# Defaults are common premade voices; use any voice_id from your account.
ELEVENLABS_VOICE_ID_MALE=pNInz6obpgDQGcFmaJgB
ELEVENLABS_VOICE_ID_FEMALE=EXAVITQu4vr4xnSDxMaL

# Deepgram — realtime speech-to-text (hearing the candidate)
DEEPGRAM_API_KEY=

# Supabase — session, transcript & feedback persistence (optional but recommended)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Optional: only set if you want the server to write with elevated rights.
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Where the browser reaches the standalone realtime WebSocket server.
# Local dev default below. In production point this at your Railway URL,
# e.g. wss://interviewiq-ws.up.railway.app
NEXT_PUBLIC_WS_URL=ws://localhost:3002

# Port the standalone WebSocket server listens on.
WS_PORT=3002

# Avatar: built-in male/female characters are used by default. Set to true to
# try /public/avatar-{male,female}.glb (only used if they contain visemes).
NEXT_PUBLIC_USE_GLB=false
